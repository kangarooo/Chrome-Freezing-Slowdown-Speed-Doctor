{
  "manifest_version": 3,
  "name": "Chrome Speed Doctor",
  "version": "1.8.4",
  "description": "Find what's slowing Chrome — real per-process CPU via CDP, RAM, extensions, apps, tabs.",
  "permissions": [
    "tabs",
    "management",
    "system.memory",
    "system.cpu",
    "scripting",
    "storage",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Speed Doctor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
